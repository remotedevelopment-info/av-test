{
    "meta": {
        "name": "Residential SDLT calculator",
        "jurisdiction": "England and Northern Ireland",
        "effectiveFrom": "2025-04-01",
        "sources": [
            "https://www.gov.uk/stamp-duty-land-tax/residential-property-rates",
            "https://www.gov.uk/guidance/stamp-duty-land-tax-buying-an-additional-residential-property"
        ]
    },
    "fields": [
        {
            "key": "purchasePrice",
            "label": "Purchase price",
            "type": "currency",
            "inputMode": "decimal",
            "min": 1,
            "step": 1,
            "placeholder": "425000",
            "help": "Enter the agreed purchase price in pounds."
        },
        {
            "key": "firstTimeBuyer",
            "label": "All buyers are first-time buyers",
            "type": "checkbox",
            "help": "First-time buyer relief only applies when the purchase price is £500,000 or less."
        },
        {
            "key": "additionalProperty",
            "label": "This is an additional property purchase",
            "type": "checkbox",
            "help": "Higher rates apply when the purchase leaves the buyer owning more than one residential property worth £40,000 or more."
        }
    ],
    "rates": {
        "standard": {
            "name": "Standard residential rates",
            "bands": [
                {
                    "upTo": 125000,
                    "rate": 0,
                    "label": "0% on the portion up to £125,000"
                },
                {
                    "upTo": 250000,
                    "rate": 0.02,
                    "label": "2% on the portion from £125,001 to £250,000"
                },
                {
                    "upTo": 925000,
                    "rate": 0.05,
                    "label": "5% on the portion from £250,001 to £925,000"
                },
                {
                    "upTo": 1500000,
                    "rate": 0.1,
                    "label": "10% on the portion from £925,001 to £1.5 million"
                },
                {
                    "upTo": null,
                    "rate": 0.12,
                    "label": "12% on the portion above £1.5 million"
                }
            ]
        },
        "firstTimeBuyer": {
            "name": "First-time buyer relief",
            "maximumEligiblePrice": 500000,
            "bands": [
                {
                    "upTo": 300000,
                    "rate": 0,
                    "label": "0% on the portion up to £300,000"
                },
                {
                    "upTo": 500000,
                    "rate": 0.05,
                    "label": "5% on the portion from £300,001 to £500,000"
                }
            ]
        },
        "additionalProperty": {
            "name": "Additional property surcharge",
            "flatRate": 0.05,
            "minimumPurchasePrice": 40000,
            "label": "5% surcharge on the full purchase price"
        }
    }
}